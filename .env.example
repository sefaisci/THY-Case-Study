# Public configuration template.
# Copy this file to .env, replace every "replace-with-..." value, and never commit .env.

# Application and API
APP_NAME=THY Agentic RAG
APP_ENV=local
APP_DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
BACKEND_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=/api/v1
API_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# PostgreSQL. Host execution uses DATABASE_URL; Compose overrides it with the service hostname.
POSTGRES_DB=thy_case_study
POSTGRES_USER=thy_app
POSTGRES_PASSWORD=local-dev-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://thy_app:local-dev-password@localhost:5432/thy_case_study
DATABASE_INTERNAL_URL=postgresql+psycopg://thy_app:local-dev-password@postgres:5432/thy_case_study

# Persistent source and processing storage
UPLOAD_DIR=./data/uploads
PAGE_IMAGE_DIR=./data/page_images
PROCESSING_DIR=./data/processing
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_EXTENSIONS=pdf,docx,pptx

# External Qdrant. Docker Compose intentionally does not start a Qdrant service.
# Qdrant is intentionally external to this Compose stack.
QDRANT_URL=https://your-qdrant-cluster.example
QDRANT_INTERNAL_URL=http://qdrant:6333
QDRANT_API_KEY=replace-with-qdrant-api-key
QDRANT_COLLECTION_SEMANTIC=semantic_chunks
QDRANT_COLLECTION_DOCLING=docling_fixed_chunks
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
QDRANT_DENSE_VECTOR_SIZE=1536

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
# Responses requests intentionally omit max_output_tokens. The selected model's
# native output capacity, context window, account limits, and request timeout remain.
OPENAI_MODEL_CACHE_SECONDS=300
MODEL_CAPABILITIES_PATH=./config/model-capabilities.v1.json
PRICING_REGISTRY_PATH=./config/pricing/openai-pricing.v1.json
EMBEDDING_MODEL=text-embedding-3-small

# Existing notebook/model defaults
SEMANTIC_CHUNKING_LLM_MODEL=gpt-5.5
SEMANTIC_CHUNKING_REASONING_EFFORT=low
SELF_SERVICE_LLM_MODEL=gpt-5.5
SELF_SERVICE_REASONING_EFFORT=low
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# Ingestion and retrieval
DOC_CONVERSION_DPI=200
SOFFICE_BINARY=
SEMANTIC_FLUSH_BATCH_SIZE=32
INGESTION_JOB_CONCURRENCY=4
SEMANTIC_PAGE_MAX_CONCURRENCY=3
DOCUMENT_MAX_CONCURRENCY=2
FIXED_CHUNK_SIZE_TOKENS=800
FIXED_CHUNK_OVERLAP_TOKENS=120
EMBEDDING_BATCH_SIZE=32
LLM_REQUEST_TIMEOUT_SECONDS=120

# Sparse-vector migration boundary. Keep stable_hash while either existing
# Qdrant collection contains legacy sparse vectors. For a fresh index, or only
# after fully reingesting both collections, change this to fastembed_bm25.
SPARSE_ENCODER_PROVIDER=stable_hash
SPARSE_ENCODER_MODEL=Qdrant/bm25
# Optional FastEmbed cache outside source-controlled paths.
SPARSE_ENCODER_CACHE_DIR=

# Retrieval stage limits. PREFETCH_K applies to each dense/sparse branch;
# COLLECTION_K is retained per selected collection; CANDIDATE_K bounds the
# balanced cross-collection union before reranking.
RAG_RUNTIME_MODE=hybrid
RETRIEVAL_PREFETCH_K=20
RETRIEVAL_COLLECTION_K=15
RERANK_CANDIDATE_K=30
RERANK_TOP_K=6
MAX_CONTEXT_CHUNKS=8
HYBRID_DENSE_WEIGHT=0.65
HYBRID_SPARSE_WEIGHT=0.35

# Production document QA uses one structured OpenAI reranker call. Empty
# RERANKER_MODEL means SELF_SERVICE_LLM_MODEL. Empty RERANKER_REASONING_EFFORT
# omits the reasoning parameter; supported configured values are minimal, low,
# medium, high, and xhigh, subject to the selected model's capabilities.
ENABLE_RERANKER=true
RERANKER_PROVIDER=openai
RERANKER_MODEL=
RERANKER_REASONING_EFFORT=low
# This independent provider-input cap protects cost even if the upstream union
# is later increased. Text from each candidate is truncated before submission.
RERANKER_MAX_CANDIDATES=30
RERANKER_TEXT_MAX_CHARS=1600
RERANK_MIN_SCORE=0.50
RERANKER_ALLOW_PARTIAL_SUPPORT=false

# Grounding is a deterministic structured evidence check, independent of the
# user's answer reasoning selection. One bounded retry absorbs an incomplete or
# transiently unparsable HTTP-200 Responses result without weakening fail-closed
# citation policy.
GROUNDING_REASONING_EFFORT=low
GROUNDING_MAX_RETRIES=1

# These thresholds apply only to explicit noop/heuristic development providers.
NO_ANSWER_MIN_SCORE=0.20
CITATION_MIN_SCORE=0.20
MAX_SESSION_HISTORY_MESSAGES=20
